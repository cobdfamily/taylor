{
  "name": "@cobd/taylor",
  "version": "1.0.21",
  "description": "Taylor MacOS compatability",
  "main": "index.js",
  "type": "commonjs",
  "scripts": {
    "build": "node-swift build && rm -rf ./lib && mv ./.build/release ./lib",
    "prepublishOnly": "tar -czvf frameworks.tar.gz ./lib && rm -rf ./lib",
    "postinstall": "tar -xzvf frameworks.tar.gz && rm *.tar.gz",
    "release": "npm version patch --no-git-tag-version && npm publish --access public"
  },
  "author": "Alex Jurgensen",
  "license": "AGPL-3.0",
  "dependencies": {},
  "devDependencies": {
    "node-swift": "git+https://github.com/kabiroberai/node-swift.git",
    "@types/node": "^22.8.6",
    "typescript": "^5.6.3"
  },
  "swift": {
    "builder": "xcode"
  },
  "files": [
    "frameworks.tar.gz",
    "README.md",
    "index.js"
  ]
}
